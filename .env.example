# Mondial uses two free data origins. Neither is required to run:
#
#  - Spine (fixtures, groups, standings, scores): openfootball/worldcup.json
#    — public domain, NO key needed, fetched automatically.
#  - Enrichment (squads, starting lineups): TheSportsDB.
#    The default free "3" test key works but caps lineups to a few players.
#    Set a Patreon key here for full squads/lineups.
THESPORTSDB_KEY=3

# Season the enrichment source queries (the spine is always 2026).
WORLD_CUP_SEASON=2026
